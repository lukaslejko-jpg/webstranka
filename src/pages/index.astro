
---
import MainLayout from '../layouts/main.astro';
import Header from '../components/Header';
import HeroSection from '../components/HeroSection';
import ClientTypesSection from '../components/ClientTypesSection';
import AboutSection from '../components/AboutSection';
import ServicesSection from '../components/ServicesSection';
import WhyUsSection from '../components/WhyUsSection';
import TeamSection from '../components/TeamSection';
import EuSupportSection from '../components/EuSupportSection';
import ContactSection from '../components/ContactSection';
import Footer from '../components/Footer';
---

<MainLayout>
  <main class="bg-cream min-h-screen">
    <Header client:load />
    <HeroSection client:load />
    <ClientTypesSection client:load />
    <AboutSection client:load />
    <ServicesSection client:load />
    <WhyUsSection client:load />
    <TeamSection client:load />
    <EuSupportSection client:load />
    <ContactSection client:load />
    <Footer client:only="react" />
  </main>
</MainLayout>

